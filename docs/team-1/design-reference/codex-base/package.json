{
  "name": "hackathon",
  "version": "1.0.0",
  "description": "Discord bot for the Hackathon OpenBoard project",
  "main": "src/bot.js",
  "scripts": {
    "start": "node src/bot.js",
    "check": "node --check src/bot.js",
    "dev": "npm run frontend:dev",
    "build": "npm run frontend:build",
    "preview": "npm run frontend:preview",
    "frontend:dev": "vite --config frontend/vite.config.mjs --host 127.0.0.1 --port 5174 --strictPort",
    "frontend:build": "vite build --config frontend/vite.config.mjs",
    "frontend:preview": "vite preview --config frontend/vite.config.mjs --host 127.0.0.1 --port 4174 --strictPort"
  },
  "keywords": [
    "discord",
    "hackathon",
    "bot"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.20.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.16"
  }
}
